# ==========================================
# Frontend Environment Variables
# ==========================================
# Copia aquest fitxer a .env (dev) o .env.production (prod build)
# Les variables VITE_* s'injecten al build time via import.meta.env

# API URL base del backend
# Dev: el proxy de Vite redirigeix /api/v1 → localhost:8000
# Prod: cal la URL completa perquè no hi ha proxy (S3+CloudFront serveix estàtics)
VITE_API_URL=/api/v1
# VITE_API_URL=https://api.matchcota.com/api/v1

# Entorn
VITE_ENVIRONMENT=development
# VITE_ENVIRONMENT=production
