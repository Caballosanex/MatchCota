# ==========================================
# Frontend Environment Variables
# ==========================================
# Copy this file to .env for local development.
# VITE_* variables are injected at build time via import.meta.env.

# Production runtime contract (AWS locked architecture)
# Frontend domain: https://matchcota.tech / https://{slug}.matchcota.tech
# API domain: https://api.matchcota.tech
VITE_API_URL=https://api.matchcota.tech
VITE_BASE_DOMAIN=matchcota.tech
VITE_ENVIRONMENT=production

# Local development override examples:
# VITE_API_URL=/api/v1
# VITE_BASE_DOMAIN=localhost
# VITE_ENVIRONMENT=development

# Legacy example removed intentionally:
# - matchcota.com domains
# - CloudFront runtime assumptions
