# ========================================
# MATCHCOTA - VARIABLES D'ENTORN
# ========================================
#
# Aquest fitxer conté totes les variables d'entorn necessàries per executar MatchCota.
#
# SETUP INICIAL:
#   1. Copia aquest fitxer: cp .env.example .env
#   2. Modifica els valors segons el teu entorn
#   3. IMPORTANT: .env NO es puja a Git (està a .gitignore)
#
# ENTORNS:
#   - development: Desenvolupament local amb Docker
#   - staging: Entorn de pre-producció
#   - production: Entorn de producció a AWS
#

# ========================================
# APPLICATION
# ========================================

# Entorn d'execució (development, staging, production)
ENVIRONMENT=development

# Mode debug (true en dev, false en producció)
DEBUG=true

# Nom i versió de l'aplicació
APP_NAME=MatchCota
APP_VERSION=0.1.0

# ========================================
# SECURITY & AUTHENTICATION
# ========================================

# Clau secreta per l'aplicació (CANVIAR EN PRODUCCIÓ!)
# Generar amb: openssl rand -hex 32
SECRET_KEY=dev-secret-key-CHANGE-IN-PRODUCTION-use-openssl-rand-hex-32

# JWT - JSON Web Token per autenticació
JWT_SECRET_KEY=dev-jwt-secret-CHANGE-IN-PRODUCTION-use-openssl-rand-hex-32
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=1440  # 24 hores (1 dia)

# ========================================
# DATABASE - PostgreSQL
# ========================================

# URL de connexió a PostgreSQL
# Format: postgresql://user:password@host:port/database
#
# Per Docker (servei db):
DATABASE_URL=postgresql://postgres:postgres@db:5432/matchcota
#
# Per localhost (si PostgreSQL corre fora de Docker):
# DATABASE_URL=postgresql://postgres:postgres@localhost:5432/matchcota
#
# Per AWS RDS (producció):
# DATABASE_URL=postgresql://matchcota_user:PASSWORD@matchcota-db.xxxxx.us-east-1.rds.amazonaws.com:5432/matchcota

# SQLAlchemy: Mostrar queries SQL al log (true només en debug)
DB_ECHO=false

# ========================================
# REDIS (CACHE) - Opcional per MVP
# ========================================

# URL de connexió a Redis
REDIS_URL=redis://redis:6379

# Activar/desactivar Redis
REDIS_ENABLED=false

# ========================================
# AWS S3 - Emmagatzematge d'imatges
# ========================================

# Credencials AWS (obtenir des de IAM Console)
AWS_ACCESS_KEY_ID=your-access-key-id
AWS_SECRET_ACCESS_KEY=your-secret-access-key
# Per credencials temporals (AWS Academy/Lab), també cal token de sessió
AWS_SESSION_TOKEN=your-session-token

# Regió AWS (Espanya: us-east-1, Frankfurt: eu-central-1)
AWS_REGION=us-east-1

# Nom del bucket S3 per uploads
S3_BUCKET_NAME=matchcota-uploads-dev

# Activar/desactivar S3 (false en dev, usar sistema de fitxers local)
S3_ENABLED=false

# ========================================
# EMAIL - SMTP
# ========================================

# Configuració SMTP
#
# En DESENVOLUPAMENT (MailHog):
SMTP_HOST=mailhog
SMTP_PORT=1025
SMTP_USER=
SMTP_PASSWORD=
SMTP_TLS=false
SMTP_SSL=false
#
# En PRODUCCIÓ (AWS SES):
# SMTP_HOST=email-smtp.us-east-1.amazonaws.com
# SMTP_PORT=587
# SMTP_USER=your-ses-smtp-username
# SMTP_PASSWORD=your-ses-smtp-password
# SMTP_TLS=true
# SMTP_SSL=false

# Email remitent
EMAIL_FROM=noreply@matchcota.tech
EMAIL_FROM_NAME=MatchCota

# ========================================
# MULTI-TENANT
# ========================================

# Subdomini per defecte per testing
DEFAULT_SUBDOMAIN=demo

# Domini base per wildcard (*.matchcota.tech)
# En desenvolupament local:
WILDCARD_DOMAIN=matchcota.local
# En producció:
# WILDCARD_DOMAIN=matchcota.tech

# ========================================
# UPLOAD LIMITS
# ========================================

# Mida màxima de fitxer (bytes)
MAX_UPLOAD_SIZE=4194304  # 4 MB

# Tipus d'imatge permesos (separats per comes)

# ========================================
# PAGINATION
# ========================================

# Resultats per pàgina per defecte
DEFAULT_PAGE_SIZE=20

# Màxim de resultats per pàgina
MAX_PAGE_SIZE=100

# ========================================
# RATE LIMITING
# ========================================

# Activar/desactivar rate limiting
RATE_LIMIT_ENABLED=false

# Requests per minut permesos
RATE_LIMIT_PER_MINUTE=60

# ========================================
# LOGGING
# ========================================

# Nivell de log (DEBUG, INFO, WARNING, ERROR, CRITICAL)
LOG_LEVEL=INFO

# ========================================
# CORS - Cross-Origin Resource Sharing
# ========================================

# Orígens permesos (només necessari si es customitza)
# Per defecte, config.py ja inclou localhost:5173 i localhost:3000
# CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ========================================
# FRONTEND - Variables VITE
# ========================================
# IMPORTANT: Variables Vite han de tenir prefix VITE_ per ser accessibles al client

# URL de l'API backend
VITE_API_URL=http://localhost:8000/api/v1

# Entorn del frontend
VITE_ENVIRONMENT=development

# Domini base per multi-tenant (sense protocol)
VITE_BASE_DOMAIN=matchcota.local

# ========================================
# NOTES IMPORTANTS
# ========================================
#
# 1. SECRETS EN PRODUCCIÓ:
#    - Generar nous SECRET_KEY i JWT_SECRET_KEY amb:
#      openssl rand -hex 32
#    - Mai compartir aquests valors
#    - Usar AWS Secrets Manager o similar en producció
#
# 2. DATABASE_URL:
#    - En Docker: usar nom del servei (db, redis)
#    - En AWS: usar endpoint de RDS
#
# 3. S3_ENABLED:
#    - false en dev: fitxers es guarden a ./backend/uploads
#    - true en prod: fitxers es guarden a S3
#
# 4. EMAIL:
#    - En dev: MailHog captura emails (UI a http://localhost:8025)
#    - En prod: AWS SES envia emails reals
#
# 5. VITE VARIABLES:
#    - Només variables amb prefix VITE_ són accessibles al navegador
#    - NO posar secrets amb prefix VITE_
#
# ========================================
